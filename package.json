{
  "name": "@felipematos/ain-cli",
  "version": "0.11.4",
  "description": "AI Node — scriptable CLI and library for LLM tasks",
  "keywords": [
    "ai",
    "llm",
    "cli",
    "openai",
    "automation",
    "scripting"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "ain": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felipematos/ain.git"
  },
  "bugs": {
    "url": "https://github.com/felipematos/ain/issues"
  },
  "homepage": "https://github.com/felipematos/ain#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm run build && npm run test",
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "json5": "^2.2.3",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
